PORT=8080
GCP_PROJECT_ID=your-gcp-project
GCS_BUCKET=your-audio-bucket
FIRESTORE_COLLECTION=call_jobs
# אם במסך Firestore מופיע Database ID שאינו (default) — למשל aisalesapp:
# FIRESTORE_DATABASE_ID=aisalesapp
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
ENABLE_CRM_DELIVERY=false
# Enable only when CRM endpoint is ready:
# CRM_WEBHOOK_URL=https://your-crm.vercel.app/api/ingest/call-insights
# CRM_HMAC_SECRET=change_me
# Optional: Firestore databaseId for multi-tenant CRM (same as x-crm-tenant-database-id in CRM docs).
# CRM_TENANT_DATABASE_ID=(default)
UPLOAD_TOKEN_SIGNING_SECRET=change_me_upload_secret
JOB_RETRY_LIMIT=5
